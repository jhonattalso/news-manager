@model News_Manager.Models.News

@{
    ViewData["Title"] = "Excluir Notícia";
}

<div class="row justify-content-center mb-5">
    <div class="col-lg-8 col-xl-7">
        
        <div class="d-flex align-items-center mb-4">
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm rounded-circle me-3" style="padding: 0.35rem 0.6rem;">
                <i class="bi bi-arrow-left"></i>
            </a>
            <div>
                <h2 class="mb-0 text-danger">Excluir Notícia</h2>
                <p class="text-muted mb-0">Esta ação não pode ser desfeita.</p>
            </div>
        </div>

        <div class="premium-card text-center border-top border-4 border-danger">
            <div class="py-4">
                <i class="bi bi-exclamation-triangle text-danger display-1 mb-4 d-block"></i>
                <h3 class="fw-bold mb-3">Tem certeza que deseja excluir?</h3>
                <p class="lead text-secondary mb-4">Você está prestes a excluir a seguinte notícia:</p>

                <div class="card bg-light border-0 text-start mx-auto mb-5 shadow-sm" style="max-width: 500px;">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-1">@Model.Title</h5>
                        <p class="text-muted small mb-0">Por @Model.Author em @Model.PublishDate.ToShortDateString()</p>
                    </div>
                </div>

                <form asp-action="Delete">
                    <input type="hidden" asp-for="Id" />
                    <div class="d-flex justify-content-center gap-3 mt-4">
                        <a asp-action="Index" class="btn btn-outline-secondary btn-lg px-4">Cancelar</a>
                        <button type="submit" class="btn btn-danger btn-lg px-5">
                            <i class="bi bi-trash-fill me-2"></i> Confirmar Exclusão
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>